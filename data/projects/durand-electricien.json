{
  "meta": {
    "projectId": "durand-electricien",
    "title": "Durand Électricité",
    "description": "Template pour artisans (plombiers, électriciens, menuisiers)",
    "version": "1.0.0",
    "template": false,
    "category": "artisan",
    "created": "2025-07-12T13:39:27.216Z",
    "lastModified": "2025-07-12T13:39:27.216Z"
  },
  "config": {
    "colors": {
      "primary": "#2563eb",
      "secondary": "#dc2626",
      "accent": "#f59e0b"
    }
  },
  "structure": {
    "pages": {
      "home": {
        "route": "/",
        "modules": [
          {
            "id": "hero_section",
            "type": "module",
            "component": "HeroSection"
          },
          {
            "id": "services_preview",
            "type": "module",
            "component": "ServicesPreview"
          }
        ]
      },
      "contact": {
        "route": "/contact",
        "modules": [
          {
            "id": "contact_form",
            "type": "module",
            "component": "ContactForm"
          }
        ]
      }
    }
  },
  "contentSchema": {
    "company": {
      "name": {
        "type": "text",
        "label": "Nom de l'entreprise",
        "default": "Durand Électricité"
      },
      "specialty": {
        "label": "Spécialité",
        "type": "select",
        "options": [
          "Plomberie",
          "Électricité",
          "Menuiserie",
          "Chauffage"
        ],
        "default": "Plomberie"
      },
      "city": {
        "type": "text",
        "label": "Ville",
        "default": "Saint-Étienne"
      },
      "phone": {
        "type": "tel",
        "label": "Téléphone",
        "default": "01 XX XX XX XX"
      },
      "email": {
        "type": "email",
        "label": "Email",
        "default": "contact@monentreprise.fr"
      }
    }
  }
}