#!/usr/bin/env node

const fs = require('fs-extra')
const path = require('path')
const JsonToReactParser = require('../src/json-to-react')
const ReactToJsonParser = require('../src/react-to-json')

async function main() {
  const args = process.argv.slice(2)
  
  if (args.includes('--round-trip')) {
    await testRoundTrip()
  } else if (args.includes('--test')) {
    await testJsonToReact()
  } else {
    console.log(`
нєЂ BuzzCraft Parser CLI

Usage:
  npm run test:generate     # Test JSON в†’ React
  npm run test:round-trip   # Test Round-Trip complet
    `)
  }
}

async function testJsonToReact() {
  console.log('н·Є Testing JSON в†’ React parser...')
  
  const examplePath = path.resolve(__dirname, '../../../data/examples/dubois-simple.json')
  const jsonProject = await fs.readJson(examplePath)
  
  const parser = new JsonToReactParser({ 
    verbose: true,
    outputDir: path.join(__dirname, '../output')
  })
  
  const result = await parser.parseProject(jsonProject)
  
  if (result.success) {
    console.log('вњ… JSON в†’ React successful!')
    console.log(`ніЃ Generated: ${result.projectPath}`)
  } else {
    console.error('вќЊ JSON в†’ React failed:', result.error)
  }
}

async function testRoundTrip() {
  console.log('нґ„ Testing Round-Trip: JSON в†’ React в†’ JSON...')
  
  try {
    // 1. Charger le JSON original
    const originalPath = path.resolve(__dirname, '../../../data/examples/dubois-simple.json')
    const originalJson = await fs.readJson(originalPath)
    console.log(`ні„ Original: ${originalJson.meta.projectId}`)
    
    // 2. JSON в†’ React
    console.log('\nнєЂ Step 1: JSON в†’ React...')
    const jsonToReact = new JsonToReactParser({ 
      verbose: true,
      outputDir: path.join(__dirname, '../output')
    })
    
    const reactResult = await jsonToReact.parseProject(originalJson)
    if (!reactResult.success) {
      throw new Error(`JSON в†’ React failed: ${reactResult.error}`)
    }
    console.log('вњ… JSON в†’ React completed')
    
    // 3. React в†’ JSON
    console.log('\nнґЌ Step 2: React в†’ JSON...')
    const reactToJson = new ReactToJsonParser({ verbose: true })
    
    const jsonResult = await reactToJson.parseProject(reactResult.projectPath)
    if (!jsonResult.success) {
      throw new Error(`React в†’ JSON failed: ${jsonResult.error}`)
    }
    console.log('вњ… React в†’ JSON completed')
    
    // 4. Comparaison
    console.log('\nнѕЇ Step 3: Comparing results...')
    const reconstructed = jsonResult.jsonProject
    
    console.log('ніЉ Comparison:')
    console.log(`  Original meta.title: "${originalJson.meta.title}"`)
    console.log(`  Reconstructed meta.title: "${reconstructed.meta.title}"`)
    console.log(`  Original meta.description: "${originalJson.meta.description}"`)
    console.log(`  Reconstructed meta.description: "${reconstructed.meta.description}"`)
    console.log(`  Original pages: ${Object.keys(originalJson.structure.pages).length}`)
    console.log(`  Reconstructed pages: ${Object.keys(reconstructed.structure.pages).length}`)
    
    // 5. Sauvegarder le rГ©sultat reconstruit
    const outputPath = path.join(__dirname, '../output/dubois-reconstructed.json')
    await fs.writeJson(outputPath, reconstructed, { spaces: 2 })
    
    console.log('\nнѕ‰ Round-Trip completed!')
    console.log(`ніЃ Original: ${originalPath}`)
    console.log(`ніЃ Reconstructed: ${outputPath}`)
    console.log('\nнґЌ Manual comparison needed for now.')
    
  } catch (error) {
    console.error('вќЊ Round-Trip failed:', error.message)
    if (error.stack) {
      console.error('Stack:', error.stack)
    }
  }
}

main().catch(console.error)
